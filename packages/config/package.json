{
  "name": "@padel/config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist && cp tailwind-preset.cjs dist/tailwind-preset.cjs",
    "lint": "biome check src test tailwind-preset.cjs package.json tsconfig.json tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind-preset": {
      "default": "./dist/tailwind-preset.cjs"
    }
  },
  "nx": {
    "tags": ["type:package", "scope:shared", "layer:config"]
  }
}
