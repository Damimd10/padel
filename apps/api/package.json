{
  "name": "@padel/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src/app.module.ts src/main.ts src/common src/competition src/prisma test package.json tsconfig.json tsconfig.build.json",
    "prisma:generate": "pnpm -w exec prisma generate --schema ./apps/api/prisma/schema.prisma",
    "prisma:migrate:dev": "pnpm -w exec prisma migrate dev --schema ./apps/api/prisma/schema.prisma",
    "prisma:migrate:deploy": "pnpm -w exec prisma migrate deploy --schema ./apps/api/prisma/schema.prisma",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/throttler": "^6.5.0",
    "@padel/schemas": "workspace:*",
    "@prisma/client": "^6.19.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.1.2",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.8",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4"
  },
  "nx": {
    "tags": ["type:app", "scope:api", "platform:backend"]
  }
}
